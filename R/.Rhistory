# Selección de variables
bbdd_pc_limpia <- bbdd_pc6 %>%
select(
Sexo,
anios_cuidado       = CP_2_1,
horas_dia           = CP_2_2,
actividad_constante = CP_2_8,
falta_tiempo        = `CP. 3.2`,
sobre_3_1 = `CP. 3.1`,
sobre_3_2 = `CP. 3.2`,
sobre_3_3 = `CP. 3.3`,
sobre_3_4 = `CP. 3.4`,
