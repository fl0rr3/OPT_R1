library(tidyverse)
library(haven)
library(dplyr)
library(car)
library(readxl)
bbdd_pc6 <- read_xlsx("../input/instrumento n6_cp2_limpio.xlsx")
instrumento_n6<- read_excel("C:/Users/flore/OneDrive/Escritorio/OPT_R1/Input/instrumento n6_cp2_limpio.xlsx")
bbdd_pc6 <- read_xlsx("../input/instrumento n6_cp2_limpio.xlsx")
View(bbdd_pc6)
bbdd_pc_limpia <- bbdd_pc6 %>%
select(
anios_cuidado   = CP_2_1,     # 2.1 Años cuidando (razón)
horas_dia       = CP_2_2,     # 2.2 Horas diarias de cuidado (razón)
ingresos_propios = CP_2_7,    # 2.7 Ingresos propios 0=No, 1=Sí (nominal)
falta_tiempo    = `CP. 3.1`,  # 3.1 Falta de tiempo personal (ordinal)
# Sección 3 completa : Variables para índice de sobrecarga
sobre_3_1 = `CP. 3.1`,
sobre_3_2 = `CP. 3.2`,
sobre_3_3 = `CP. 3.3`,
sobre_3_4 = `CP. 3.4`,
sobre_3_5 = `CP. 3.5`,
sobre_3_6 = `CP. 3.6`,
sobre_3_7 = `CP. 3.7`)
View(bbdd_pc_limpia)
# 4.1 anios_cuidado: convertir a numérico
# Hay 3 casos con valor ">1" → se recodifican como 1 (menos de 2 años)
base <- base %>%
mutate(
anios_cuidado = case_when(
anios_cuidado == ">1" ~ "1",
TRUE ~ as.character(anios_cuidado)),
anios_cuidado = as.numeric(anios_cuidado))
# 4.1 anios_cuidado: convertir a numérico
# Hay 3 casos con valor ">1" → se recodifican como 1 (menos de 2 años)
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
anios_cuidado = case_when(
anios_cuidado == ">1" ~ "1",
TRUE ~ as.character(anios_cuidado)),
anios_cuidado = as.numeric(anios_cuidado))
# 4.2 horas_dia: ya numérica, verificar
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(horas_dia = as.numeric(horas_dia))
# 4.3 ingresos_propios: recodificar 99 como NA, convertir a factor
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
ingresos_propios = na_if(ingresos_propios, 99),
ingresos_propios = factor(ingresos_propios,
levels = c(0, 1),
labels = c("No", "Sí")))
# 4.4 falta_tiempo: convertir a factor ordenado (ordinal 1-5)
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
falta_tiempo = factor(falta_tiempo,
levels = 1:5,
labels = c("Nunca",
"Rara vez",
"Algunas veces",
"Bastantes veces",
"Casi siempre"),
ordered = TRUE))
View(bbdd_pc_limpia)
attr(base$anios_cuidado,    "label") <- "Años que lleva cuidando a la persona dependiente"
attr(bbdd_pc_limpia$anios_cuidado,    "label") <- "Años que lleva cuidando a la persona dependiente"
attr(bbdd_pc_limpia$horas_dia,        "label") <- "Horas diarias dedicadas al cuidado"
attr(bbdd_pc_limpia$ingresos_propios, "label") <- "¿Cuenta con ingresos propios? (0=No, 1=Sí)"
attr(bbdd_pc_limpia$falta_tiempo,     "label") <- "¿Siente que no tiene tiempo para usted? (1=Nunca, 5=Casi siempre)"
attr(bbdd_pc_limpia$indice_sobrecarga,"label") <- "Índice de sobrecarga: suma ítems 3.1 a 3.7 (rango 7-35)"
View(bbdd_pc6)
View(bbdd_pc6)
View(bbdd_pc_limpia)
library(tidyverse)
library(haven)
library(dplyr)
library(car)
library(readxl)
bbdd_pc6 <- read_xlsx("../input/instrumento n6_cp2_limpio.xlsx")
bbdd_pc6 <- read_xlsx("../input/instrumento n6_cp2_limpio.xlsx")
bbdd_pc_limpia <- bbdd_pc6 %>%
select(
anios_cuidado   = CP_2_1,     # 2.1 Años cuidando (razón)
horas_dia       = CP_2_2,     # 2.2 Horas diarias de cuidado (razón)
ingresos_propios = CP_2_8,    # 2.8 Desarrolla alguna otra actividad constante fuera de la casa 0=No, 1=Sí (nominal)
falta_tiempo    = `CP. 3.2` )   # 3.1 Falta de tiempo personal (ordinal)
# Sección 3 completa : Variables para índice de sobrecarga
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
indice_sobrecarga = rowSums(
select(., `CP. 3.1`, `CP. 3.2`, `CP. 3.3`,
`CP. 3.4`, `CP. 3.5`, `CP. 3.6`, `CP. 3.7`),
na.rm = FALSE
)
)
bbdd_pc_limpia <- bbdd_pc6 %>%
select(
anios_cuidado   = CP_2_1,     # 2.1 Años cuidando (razón)
horas_dia       = CP_2_2,     # 2.2 Horas diarias de cuidado (razón)
ingresos_propios = CP_2_8,    # 2.8 Desarrolla alguna otra actividad constante fuera de la casa 0=No, 1=Sí (nominal)
falta_tiempo    = `CP. 3.2`,   # 3.1 Falta de tiempo personal (ordinal)
# Sección 3 completa : Variables para índice de sobrecarga
sobre_3_1 = `CP. 3.1`,
sobre_3_2 = `CP. 3.2`,
sobre_3_3 = `CP. 3.3`,
sobre_3_4 = `CP. 3.4`,
sobre_3_5 = `CP. 3.5`,
sobre_3_6 = `CP. 3.6`,
sobre_3_7 = `CP. 3.7`)
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
indice_sobrecarga = rowSums(
select(., `CP. 3.1`, `CP. 3.2`, `CP. 3.3`,
`CP. 3.4`, `CP. 3.5`, `CP. 3.6`, `CP. 3.7`),
na.rm = FALSE))
bbdd_pc_limpia <- bbdd_pc_limpia %>%
mutate(
indice_sobrecarga = rowSums(
select(., sobre_3_1:sobre_3_7),
na.rm = FALSE))
attr(bbdd_pc_limpia$anios_cuidado,    "label") <- "Años que lleva cuidando a la persona dependiente"
attr(bbdd_pc_limpia$horas_dia,        "label") <- "Horas diarias dedicadas al cuidado"
attr(bbdd_pc_limpia$ingresos_propios, "label") <- "¿Cuenta con ingresos propios? (0=No, 1=Sí)"
attr(bbdd_pc_limpia$falta_tiempo,     "label") <- "¿Siente que no tiene tiempo para usted? (1=Nunca, 5=Casi siempre)"
attr(bbdd_pc_limpia$indice_sobrecarga,"label") <- "Índice de sobrecarga: suma ítems 3.1 a 3.7 (rango 7-35)"
View(bbdd_pc_limpia)
attr(bbdd_pc_limpia$anios_cuidado,    "label") <- "Años que lleva cuidando a la persona dependiente"
attr(bbdd_pc_limpia$horas_dia,        "label") <- "Horas diarias dedicadas al cuidado"
attr(bbdd_pc_limpia$ingresos_propios, "label") <- "¿Cuenta con ingresos propios? (0=No, 1=Sí)"
attr(bbdd_pc_limpia$falta_tiempo,     "label") <- "¿Siente que no tiene tiempo para usted? (1=Nunca, 5=Casi siempre)"
attr(bbdd_pc_limpia$indice_sobrecarga,"label") <- "Índice de sobrecarga: suma ítems 3.1 a 3.7 (rango 17-35)"
View(bbdd_pc_limpia)
media_horas  <- mean(base$horas_dia, na.rm = TRUE)
media_horas  <- mean(bbdd_pc_limpia$horas_dia, na.rm = TRUE)
mediana_horas <- median(bbdd_pc_limpia$horas_dia, na.rm = TRUE)
grafico1 <- ggplot(bbdd_pc_limpia %>% filter(!is.na(horas_dia)),
aes(x = horas_dia)) +
geom_histogram(binwidth = 2, fill = "#5DCAA5", color = "white", alpha = 0.85) +
geom_vline(aes(xintercept = media_horas, linetype = "Media"),
color = "#0F6E56", linewidth = 0.9) +
geom_vline(aes(xintercept = mediana_horas, linetype = "Mediana"),
color = "#3C3489", linewidth = 0.9) +
scale_linetype_manual(
name = "",
values = c("Media" = "dashed", "Mediana" = "dotted")
) +
annotate("text", x = media_horas + 0.6, y = 18,
label = paste0("Media = ", round(media_horas, 1), " hrs"),
color = "#0F6E56", size = 3.5, hjust = 0) +
annotate("text", x = mediana_horas + 0.6, y = 16,
label = paste0("Mediana = ", mediana_horas, " hrs"),
color = "#3C3489", size = 3.5, hjust = 0) +
labs(
title    = "Gráfico 1. Distribución de horas diarias dedicadas al cuidado",
subtitle = "Cuidadoras/es del PRLAC, comuna de Independencia",
x        = "Horas diarias",
y        = "Frecuencia",
caption  = "Fuente: Instrumento PC N°06, PRLAC") +
theme_minimal(base_size = 12) +
theme(
plot.title    = element_text(face = "bold", size = 12),
plot.subtitle = element_text(color = "grey50", size = 10),
legend.position = "bottom")
print(grafico1)
